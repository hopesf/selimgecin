{
  "name": "selimgecin",
  "version": "0.1.1",
  "description": "Selim Gecin About",
  "type": "module",
  "bin": {
    "selimgecin": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "postbuild": "node -e \"const fs=require('fs'); const f='dist/index.js'; let c=fs.readFileSync(f,'utf8'); if(!c.startsWith('#!/usr/bin/env node')) { c='#!/usr/bin/env node\\n'+c; fs.writeFileSync(f,c); }\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hopesf/selimgecin.git"
  },
  "keywords": [
    "selimgecin",
    "hopesf",
    "selimcoder",
    "selimgeçin"
  ],
  "author": "Selim Geçin - <gecin18@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/hopesf/selimgecin/issues"
  },
  "homepage": "https://github.com/hopesf/selimgecin#readme",
  "dependencies": {
    "@inquirer/search": "^4.1.4",
    "chalk": "^5.6.2",
    "got": "^14.6.6",
    "inquirer": "^13.3.0",
    "open": "^11.0.0",
    "terminal-image": "^4.2.0",
    "word-wrap": "^1.2.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.2"
  }
}
